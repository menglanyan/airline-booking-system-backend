SERVER_PORT=8082

# MYSQL CONNECTION
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/YOUR_DATABASE_NAME
SPRING_DATASOURCE_USERNAME=YOUR_DB_USERNAME
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD!

# Use 'update' only during development
SPRING_JPA_DDL_AUTO=update

JWT_SECRET=YOUR_SECRET_KEY_NOT_LESS_THAN_32_CHARS

# Mail configuration
MAIL_USERNAME=YOUR_GMAIL_USERNAME
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD

FRONTEND_LOGIN_URL=LOGIN_PAGE_URL
VIEW_BOOKING_URL=MY_BOOKINGS_PAGE_URL